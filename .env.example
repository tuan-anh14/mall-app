# ── App environment ──────────────────────────────────────────────────────────
# development | preview | production
APP_ENV=development

# ── API ───────────────────────────────────────────────────────────────────────
API_BASE_URL=https://mall-be-dgpi.onrender.com

# ── Sentry (error tracking) ───────────────────────────────────────────────────
SENTRY_DSN=

# ── EAS (required for builds/updates) ────────────────────────────────────────
# Get from: https://expo.dev → your project → Settings
EAS_PROJECT_ID=YOUR_EAS_PROJECT_ID
